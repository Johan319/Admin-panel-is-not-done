	for _, plr in ipairs(Players:GetPlayers()) do
		if plr:GetRankInGroup(1234567) >= 100 then -- Change group ID + rank as needed
			adminCount += 1
		end
	end
	adminsValueLabel.Text = tostring(adminCount)

