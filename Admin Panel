	local uptimeSeconds = tick() - serverStartTime
	local hours = math.floor(uptimeSeconds / 3600)
	local minutes = math.floor((uptimeSeconds % 3600) / 60)
	uptimeValueLabel.Text = (hours > 0 and hours .. "h " .. minutes .. "m") or (minutes .. "m")
end)

